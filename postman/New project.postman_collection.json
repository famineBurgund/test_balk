    {
      "name": "Works locally",
      "item": [
        {
          "name": "Invoice local",
          "item": [
            {
              "name": "Get last interval AT",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/soap/invoice/last-interval-at"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status is 200', function () {",
                      "  pm.response.to.have.status(200);",
                      "});",
                      "pm.test('Response is JSON object', function () {",
                      "  var body = pm.response.json();",
                      "  pm.expect(body).to.be.an('object');",
                      "  pm.expect(body).to.have.property('lastInterval');",
                      "});"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Get last interval NMTP",
