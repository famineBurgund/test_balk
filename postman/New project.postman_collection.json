        {
          "name": "Database-backed API",
          "item": [
            {
              "name": "Get wagons",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/api/wagons"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status is 200', function () {",
                      "  pm.response.to.have.status(200);",
                      "});",
                      "pm.test('Wagons response is array', function () {",
                      "  var body = pm.response.json();",
                      "  pm.expect(body).to.be.an('array');",
                      "  pm.expect(body.length).to.be.greaterThan(0);",
                      "});"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Get filed wagons",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/api/wagons/filed"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status is 200', function () {",
                      "  pm.response.to.have.status(200);",
                      "});",
                      "pm.test('All returned wagons are open', function () {",
                      "  var body = pm.response.json();",
                      "  pm.expect(body).to.be.an('array');",
                      "  body.forEach(function (item) { pm.expect(item.cleaned_at).to.be.oneOf([null, undefined]); });",
                      "});"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Get clean wagons",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/api/wagons/clean"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status is 200', function () {",
                      "  pm.response.to.have.status(200);",
                      "});",
                      "pm.test('All returned wagons are cleaned', function () {",
                      "  var body = pm.response.json();",
                      "  pm.expect(body).to.be.an('array');",
                      "  body.forEach(function (item) { pm.expect(item.cleaned_at).to.not.be.oneOf([null, undefined]); });",
                      "});"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Get wagon history",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/api/wagons/{{wagonHistoryNumber}}"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status is 200', function () {",
                      "  pm.response.to.have.status(200);",
                      "});",
                      "pm.test('History belongs to requested wagon', function () {",
                      "  var body = pm.response.json();",
                      "  pm.expect(body).to.be.an('array');",
                      "  body.forEach(function (item) { pm.expect(item.wagon_number).to.eql(pm.environment.get('wagonHistoryNumber')); });",
                      "});"
                    ]
                  }
                }
              ]
            }
          ]
        },
        {
          "name": "Logs and diagnostics",
          "item": [
            {
              "name": "Get recent logs",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/soap/logs?minutes=30"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status is 200', function () {",
                      "  pm.response.to.have.status(200);",
                      "});",
                      "pm.test('Logs response shape is correct', function () {",
                      "  var body = pm.response.json();",
                      "  pm.expect(body.status).to.eql('success');",
                      "  pm.expect(body.logs).to.be.an('array');",
                      "});"
                    ]
                  }
                }
              ]
            }
          ]
        }
